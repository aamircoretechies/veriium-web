# =============================================================================
# Veriium — environment variables
# Copy to `.env.local` for local development.
# =============================================================================

# -----------------------------------------------------------------------------
# Phase 0 — Required (Airtable REST + QStash plumbing)
# -----------------------------------------------------------------------------

# Airtable — API credentials and base
# PAT for `npm run airtable:setup-staging` also needs schema.bases:read + schema.bases:write
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Airtable — table IDs (from base schema; not display names)
AIRTABLE_TABLE_DRIVERS=
AIRTABLE_TABLE_MECHANICS=
AIRTABLE_TABLE_JOBS=
AIRTABLE_TABLE_DIAGNOSES=
AIRTABLE_TABLE_PAYMENTS=
AIRTABLE_TABLE_ACTION_ITEMS=

# QStash — publish delayed jobs and verify incoming worker requests
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=

# Public app URL used as the QStash callback base
# Local: http://localhost:3000 (use ngrok URL when testing QStash end-to-end)
# Production: https://veriium.com
APP_URL=

# -----------------------------------------------------------------------------
# Phase 0 — Optional
# -----------------------------------------------------------------------------

# QStash API endpoint (defaults to https://qstash.upstash.io)
# QSTASH_URL=https://qstash.upstash.io

# -----------------------------------------------------------------------------
# Phase 1 — Required (mechanic onboarding: Twilio OTP/SMS, sessions, webhooks)
# -----------------------------------------------------------------------------

# Local `next dev` (NODE_ENV=development): OTP skips Twilio Verify and logs a
# fixed code `000000` to the server console. Twilio vars may be left blank
# (placeholders are applied). Outbound SMS still needs real Twilio credentials.
#
# On Vercel (NODE_ENV is always production): set ALLOW_DEV_OTP=true on Preview
# (or a test project) to use the same fixed `000000` OTP. Do NOT enable on
# Production. Redeploy after changing the var.
# ALLOW_DEV_OTP=true
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_MESSAGING_SERVICE_SID=
MECHANIC_SESSION_SECRET=
AIRTABLE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Phase 1 — Optional
# -----------------------------------------------------------------------------

# TWILIO_PHONE_NUMBER=

# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# VERIIUM_SUPPORT_PHONE=

# -----------------------------------------------------------------------------
# Phase 2 — Required (AI diagnosis)
# -----------------------------------------------------------------------------

OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Phase 2 — Optional
# -----------------------------------------------------------------------------

# DIAGNOSIS_AI_MODEL=gpt-4o-mini
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Phase 3 — Required (booking: HMAC-signed driver job URLs)
# Generate: openssl rand -base64 32
# -----------------------------------------------------------------------------

SIGNED_URL_SECRET=

# -----------------------------------------------------------------------------
# Phase 4 — Required (matching funnel + dev start-matching trigger)
# -----------------------------------------------------------------------------

# E.164 admin phone for Tier 4 manual-match alert SMS
VERIIUM_ADMIN_PHONE=

# Protects POST /api/jobs/{jobId}/start-matching (local/dev)
# Generate: openssl rand -base64 24
MATCHING_DEV_SECRET=

# -----------------------------------------------------------------------------
# Phase 4 — Optional
# -----------------------------------------------------------------------------

# Override tier escalation delays (seconds from matched_at) for local testing
# MATCHING_TIER_DELAYS_SECONDS=60,90,120

# -----------------------------------------------------------------------------
# Phase 5 — Required (Stripe payments: SetupIntent, webhooks, Elements)
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: stripe listen --forward-to localhost:3000/api/webhooks/stripe
# -----------------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional Stripe idempotency key prefixes (defaults match lib/stripe/idempotency.ts)
# PAYMENT_KEY_PREFIX_SETUP=setup-
# PAYMENT_KEY_PREFIX_DIAGNOSTIC=diagnostic-
# PAYMENT_KEY_PREFIX_CANCEL=cancel-
# PAYMENT_KEY_PREFIX_TIP=tip-
# PAYMENT_KEY_PREFIX_RECOVERY=recovery-
# PAYMENT_KEY_PREFIX_INSTALLED=installed-
# PAYMENT_KEY_PREFIX_PARTS_CANCEL=parts-cancel-

# -----------------------------------------------------------------------------
# Find Mechanic — Optional (public browse search at /api/mechanics/search)
# -----------------------------------------------------------------------------

# Search data source for GET /api/mechanics/search.
# 1 = in-memory fixtures (no Airtable required for mechanic browse)
# 0 = live Airtable — set once AIRTABLE_API_KEY and AIRTABLE_BASE_ID are configured
# When unset, uses live Airtable if configured; otherwise falls back to fixtures.
FIND_MECHANIC_MOCK=1

# -----------------------------------------------------------------------------
# Phase 6 — Optional (edge cases: cancellation, no-show, disputes, stale availability)
# No new required keys — reuses Phase 0–5 infrastructure above.
# -----------------------------------------------------------------------------

# Mock QStash publish during `npm run phase6:manual-test` (invoke workers directly)
# PHASE6_MANUAL_TEST=1

# Shorten timers for local / manual testing (defaults shown)
# NO_SHOW_DELAY_SECONDS=900
# DISPUTE_REMINDER_DELAYS_SECONDS=86400,172800,259200
# STALE_AVAILABILITY_SECONDS=604800
# CANCELLATION_FREE_HOURS=24
# QUOTE_TIMEOUT_SECONDS=7200
# RECEIPT_DEADLINE_SECONDS=86400
# PAYMENT_RETRY_DELAY_SECONDS=86400

# QStash end-to-end locally: expose dev server (ngrok) and set APP_URL to the public URL
# so scheduled no-show / dispute / stale workers can POST back to your machine.

# Airtable automations (ops — wire in Airtable, not in code):
#   Job status no_show_pending_review → admin approves →
#     POST /api/webhooks/airtable/jobs  { "recordId": "<jobId>", "action": "no_show_approved" }
#   Job status disputed → admin refunds →
#     POST /api/webhooks/airtable/jobs  { "recordId": "<jobId>", "action": "dispute_refund" }
#   Job status disputed → admin confirms charge →
#     POST /api/webhooks/airtable/jobs  { "recordId": "<jobId>", "action": "dispute_confirm" }
#   Job status quote_pending_admin → admin releases high-parts quote →
#     POST /api/webhooks/airtable/jobs  { "recordId": "<jobId>", "action": "quote_parts_approved" }
